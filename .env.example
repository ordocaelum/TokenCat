SUPABASE_DB_DSN=postgresql://<user>:<password>@<host>:5432/<dbname>
LLM_UPSTREAM=https://api.openai.com
LLMLINGUA_RATE=0.7
LLM_PRICE_PER_1K=0.005
# Required: gateway secret — must be at least 32 characters, must not be "tokencat_secret_fallback"
TOKENCAT_API_KEY=<your-gateway-secret-min-32-chars>
# Required: upstream LLM API key injected by the proxy into every upstream request
LLM_UPSTREAM_KEY=<your-upstream-api-key>
